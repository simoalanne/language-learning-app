{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"]
}
